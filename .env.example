# ── Backend (set in Railway project environment variables) ──────────────────

# Required: Groq LLM API key (get one free at console.groq.com)
groq_api_key=your_groq_api_key_here

# Required: HuggingFace API key for embeddings model (all-MiniLM-L6-v2)
huggingface_api_key=your_huggingface_api_key_here

# CORS origins (comma-separated) — in Railway, set to your Vercel production URL
# Example: ALLOWED_ORIGINS=https://docbot.vercel.app,http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000

# Set automatically by Railway — do not set manually
# PORT=8000


# ── Frontend (set in Vercel project environment variables) ───────────────────

# Railway backend URL — required in production for API proxy
# Example: RAILWAY_BACKEND_URL=https://docbot-production.up.railway.app
RAILWAY_BACKEND_URL=https://your-app.up.railway.app


# ── PostgreSQL (DOCBOT-102) ──────────────────────────────────────────────────

# Required for v2. Format: postgresql://<user>:<password>@<host>:<port>/<dbname>
#
# ON RAILWAY: Do NOT set manually. Add the PostgreSQL plugin to your Railway project,
# then reference it in the DocBot service variables:
#   DATABASE_URL=${{Postgres.DATABASE_URL}}
#
# LOCAL DEV (Docker):
#   docker run --name docbot-pg -e POSTGRES_PASSWORD=postgres \
#     -e POSTGRES_DB=docbot_dev -p 5432:5432 -d postgres:15
#   Then set:
#   DATABASE_URL=postgresql://postgres:postgres@localhost:5432/docbot_dev
#
# NEVER commit a real DATABASE_URL to version control.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/docbot_dev


# ── Azure SQL — Microsoft Entra Interactive Auth (DOCBOT-208) ────────────────

# Client ID of your Azure AD app registration.
# Required to enable "Sign in with Microsoft" on the Azure SQL connection form.
#
# Setup (one-time, in Azure Portal):
#   1. Azure Active Directory → App registrations → New registration
#   2. Add redirect URIs:
#        http://localhost:3000   (local dev)
#        https://<your-app>.vercel.app   (production)
#   3. API permissions → Add → Azure SQL Database → user_impersonation → Grant admin consent
#   4. Copy the Application (client) ID below
#
# Set in Vercel project environment variables for production.
NEXT_PUBLIC_AZURE_CLIENT_ID=your_azure_ad_app_client_id_here


# ── On-Premise Docker Compose (DOCBOT-605) ───────────────────────────────────
#
# Quick start:
#   cp .env.example .env
#   # Fill in GROQ_API_KEY, HUGGINGFACE_API_KEY, DB_ENCRYPTION_KEY below
#   docker compose up -d
#
# Ollama (fully air-gapped, no Groq required):
#   DOCBOT_LLM_PROVIDER=ollama docker compose --profile ollama up -d

# PostgreSQL credentials for the embedded postgres container
POSTGRES_USER=docbot
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=docbot

# LLM provider: "groq" (default, requires GROQ_API_KEY) or "ollama" (air-gapped)
DOCBOT_LLM_PROVIDER=groq

# Groq API key — required when DOCBOT_LLM_PROVIDER=groq
GROQ_API_KEY=your_groq_api_key_here

# HuggingFace API key — required for document embeddings
HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# Credential encryption key — REQUIRED, must be a Fernet key
# Generate one: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
DB_ENCRYPTION_KEY=

# E2B sandbox API key — optional, enables Python analysis feature
E2B_API_KEY=

# Ollama settings — only used when DOCBOT_LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1:8b

# Port overrides — defaults shown
BACKEND_PORT=8000
FRONTEND_PORT=3000


# ── SSO / SAML (DOCBOT-601) ───────────────────────────────────────────────────
# Leave blank to disable SSO (app works without it).
# Set all five to enable SAML 2.0 login with Okta or Azure AD.
#
# SP (DocBot) settings:
SAML_SP_ENTITY_ID=https://your-docbot-domain.com
SAML_SP_ACS_URL=https://your-docbot-domain.com/api/auth/saml/acs
#
# IdP settings — copy from Okta / Azure AD app configuration:
SAML_IDP_ENTITY_ID=
SAML_IDP_SSO_URL=
SAML_IDP_X509_CERT=
#
# Optional — SP-signed requests (paste SP cert + key if your IdP requires signed AuthnRequests):
SAML_SP_X509_CERT=
SAML_SP_PRIVATE_KEY=
#
# Session TTL in hours (default 8)
SESSION_TTL_HOURS=8
# Frontend URL for post-SSO redirect
FRONTEND_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Public-deployment abuse guards (all OFF by default — enable for public links)
# See api/utils/request_guard.py
# ---------------------------------------------------------------------------
# Hard block uploads / live-DB connect / connector+EDGAR ingestion for EVERYONE
# (except owner). Public link then only exercises the demo dataset. Use this OR
# GATE_UPLOADS below — not both. GATE_UPLOADS is the recommended public model.
PUBLIC_DEMO_MODE=false
#
# Recommended public model: anonymous visitors get demo + chat; uploading your
# own data (PDF/CSV/live-DB) requires a free GitHub/Google sign-in. Lets users
# actually test while capping cost per real identity.
GATE_UPLOADS=true
# Per-authenticated-user daily weighted budget (chat=1, hybrid/sandbox=2,
# autopilot=5). Resets at UTC midnight. 0 disables. 80 = ~16 autopilot runs/day.
USER_DAILY_BUDGET=80
#
# Per-IP sliding-window request limit on /api/ POST+DELETE. 0 disables.
RATE_LIMIT_PER_MIN=20
# Per-ANONYMOUS-session weighted op budget (demo/chat). 0 disables.
SESSION_BUDGET=40
# Owner bypass: a request presenting this key (header X-Owner-Key, ?owner_key=<key>,
# or the docbot_owner cookie) skips ALL guards above. Leave blank to disable.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
OWNER_KEY=
